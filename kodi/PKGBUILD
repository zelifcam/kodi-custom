pkgver() {
  cd kodi
  printf "r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  rm -rf "$srcdir/kodi-build"
  mkdir -p "$srcdir/kodi-build"
}

build() {
  export JAVA_HOME=/usr/lib/jvm/java-17-openjdk
  export PATH="$JAVA_HOME/bin:$PATH"
  # GCC 15 has ICEs in multiple -O2 passes; drop to -O1 for C and C++
  export CFLAGS="${CFLAGS/-O2/-O1}"
  export CXXFLAGS="${CXXFLAGS/-O2/-O1}"

  /opt/cmake3/bin/cmake -S kodi -B "$srcdir/kodi-build" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_FLAGS_RELEASE="-O1 -DNDEBUG" \
    -DCMAKE_CXX_FLAGS_RELEASE="-O1 -DNDEBUG" \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_INSTALL_LIBDIR=/usr/lib \
    -DCMAKE_EXE_LINKER_FLAGS="-fuse-ld=bfd" \
    -DCMAKE_SHARED_LINKER_FLAGS="-fuse-ld=bfd" \
    -DCORE_PLATFORM_NAME=gbm \
    -DAPP_RENDER_SYSTEM=gles \
    -DENABLE_GBM=ON \
    -DENABLE_X11=OFF \
    -DENABLE_WAYLAND=OFF \
    -DENABLE_TESTING=OFF \
    -DENABLE_INTERNAL_FFMPEG=ON \
    -DENABLE_INTERNAL_CROSSGUID=ON \
    -DENABLE_INTERNAL_FSTRCMP=ON \
    -DENABLE_INTERNAL_FLATBUFFERS=ON \
    -DENABLE_INTERNAL_UDFREAD=ON \
    -DENABLE_INTERNAL_RapidJSON=OFF \
    -DENABLE_INTERNAL_EXIV2=ON \
    -DENABLE_VAAPI=ON \
    -DENABLE_VDPAU=ON \
    -DENABLE_CEC=ON \
    -DENABLE_MYSQLCLIENT=ON \
    -DMYSQL_INCLUDE_DIR=/usr/include/mysql \
    -Dlibdvdcss_URL="$srcdir/libdvdcss-${_libdvdcss_version}.tar.gz" \
    -Dlibdvdnav_URL="$srcdir/libdvdnav-${_libdvdnav_version}.tar.gz" \
    -Dlibdvdread_URL="$srcdir/libdvdread-${_libdvdread_version}.tar.gz" \
    -DFFMPEG_URL="$srcdir/ffmpeg-${_ffmpeg_version}.tar.xz" \
    -DCROSSGUID_URL="$srcdir/crossguid-${_crossguid_version}.tar.gz" \
    -DFSTRCMP_URL="$srcdir/fstrcmp-${_fstrcmp_version}.tar.gz" \
    -DFLATBUFFERS_URL="$srcdir/flatbuffers-${_flatbuffers_version}.tar.gz" \
    -DUDFREAD_URL="$srcdir/libudfread-${_libudfread_version}.tar.bz2"

  /opt/cmake3/bin/cmake --build "$srcdir/kodi-build" -j"$(nproc)"
}

package() {
  cd "$srcdir/kodi-build"
  for _cmp in kodi kodi-bin; do
    DESTDIR="$pkgdir" /opt/cmake3/bin/cmake \
      -DCMAKE_INSTALL_COMPONENT="$_cmp" \
      -P cmake_install.cmake
  done

  mkdir -p "$pkgdir/usr/lib/kodi/addons"
  # Replace Kodi's bundled cert with the system cert store
  rm -f "$pkgdir/usr/share/kodi/system/certs/cacert.pem"
  ln -s /etc/ssl/cert.pem "$pkgdir/usr/share/kodi/system/certs/cacert.pem"
}
